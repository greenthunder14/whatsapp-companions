# ── WhatsApp Cloud API ─────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_token_here
WEBHOOK_VERIFY_TOKEN=my_secret_word_123

# ── Anthropic (Claude AI) ──────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Dashboard ──────────────────────────────────────────────────
# Optional: set a password to protect your dashboard
# Leave blank for no password (fine for local use)
DASHBOARD_PASSWORD=

# ── Daily Check-ins ────────────────────────────────────────────
# Set to true to enable companions messaging users daily
ENABLE_CHECKINS=false

# Time to send check-ins (cron format, default = 10:00 AM daily)
# Format: "minute hour * * *"
# Examples:
#   "0 10 * * *"  = 10:00 AM every day
#   "0 9 * * 1"   = 9:00 AM every Monday only
#   "0 20 * * *"  = 8:00 PM every day
CHECKIN_TIME=0 10 * * *

# ── Server ─────────────────────────────────────────────────────
PORT=3000
